{
  "name": "panclaw",
  "version": "0.4.2",
  "description": "Audited skill router for OpenClaw and Hermes-style agents.",
  "api": {
    "type": "http",
    "base_url": "http://127.0.0.1:8787",
    "skills_endpoint": "/skills",
    "run_endpoint_template": "/skills/{skill_id}/run",
    "manifest_endpoint": "/integrations/openclaw/manifest",
    "plugins_endpoint": "/plugins"
  },
  "security": {
    "default_mode": "dry_run",
    "approval_env": "PANCLAW_APPROVAL_TOKEN",
    "audit_env": "PANCLAW_AUDIT_LOG"
  }
}
